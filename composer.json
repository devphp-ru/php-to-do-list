    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "process-timeout": 0
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "require": {
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-curl": "*"
  }
}