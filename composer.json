{
  "authors": [
    {
      "name": "devphp-ru"
    }
  ],
  "description": "ToDoList - PHP 8.4",
  "autoload": {
    "psr-4": {
      "App\\": "src",
      "Framework\\": "framework"
    },
    "files": [
      "framework/helpers.php"
    ]
  },
